# Atlassian RAG Exporter — environment variables
# Copy to .env and fill in your values

# === Atlassian ===
ATLASSIAN_BASE_URL=https://your-company.atlassian.net
ATLASSIAN_EMAIL=you@company.com
ATLASSIAN_TOKEN=ATATT3xFfGF0...

# === RAG API auth (optional) ===
ATLASSIAN_RAG_API_TOKEN=your-secret-token

# === LLM (OpenAI-compatible) ===
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=mistral

# === Vector DB (choose one) ===
# Qdrant (default)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Pinecone
PINECONE_API_KEY=

# Weaviate
WEAVIATE_URL=http://localhost:8080

# pgvector / PostgreSQL
PGVECTOR_DSN=postgresql://user:pass@localhost:5432/ragdb
